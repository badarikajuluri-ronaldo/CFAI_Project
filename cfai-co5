# ------------------------------------
# REJECTION SAMPLING
# ------------------------------------

def rejection_sampling(samples=1000):

    accepted = 0
    cheating_count = 0

    for _ in range(samples):

        cheating = random.random() < P_CHEATING

        face = random.random() < (
            P_FACE_MISSING_GIVEN_CHEATING
            if cheating
            else P_FACE_MISSING_GIVEN_NOT_CHEATING
        )

        if face:

            accepted += 1

            if cheating:
                cheating_count += 1

    if accepted == 0:
        return 0

    return cheating_count / accepted



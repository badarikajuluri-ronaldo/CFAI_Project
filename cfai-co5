import random


# ------------------------------------
# CO5 : BAYESIAN PROCTORING SYSTEM
# ------------------------------------

print("CO5 : Bayesian Network Based Exam Proctoring")
print("--------------------------------------------")


# PRIOR PROBABILITY

P_CHEATING = 0.20
P_NOT_CHEATING = 0.80


# CONDITIONAL PROBABILITIES (CPT)

P_FACE_MISSING_GIVEN_CHEATING = 0.70
P_FACE_MISSING_GIVEN_NOT_CHEATING = 0.10

P_TAB_SWITCH_GIVEN_CHEATING = 0.80
P_TAB_SWITCH_GIVEN_NOT_CHEATING = 0.15

P_LOOKING_AWAY_GIVEN_CHEATING = 0.75
P_LOOKING_AWAY_GIVEN_NOT_CHEATING = 0.20


# ------------------------------------
# BAYES RULE
# ------------------------------------

def bayes_cheating(face_missing, tab_switch, looking_away):

    if face_missing:
        p_face_cheat = P_FACE_MISSING_GIVEN_CHEATING
        p_face_not = P_FACE_MISSING_GIVEN_NOT_CHEATING
    else:
        p_face_cheat = 1 - P_FACE_MISSING_GIVEN_CHEATING
        p_face_not = 1 - P_FACE_MISSING_GIVEN_NOT_CHEATING

    if tab_switch:
        p_tab_cheat = P_TAB_SWITCH_GIVEN_CHEATING
        p_tab_not = P_TAB_SWITCH_GIVEN_NOT_CHEATING
    else:
        p_tab_cheat = 1 - P_TAB_SWITCH_GIVEN_CHEATING
        p_tab_not = 1 - P_TAB_SWITCH_GIVEN_NOT_CHEATING

    if looking_away:
        p_look_cheat = P_LOOKING_AWAY_GIVEN_CHEATING
        p_look_not = P_LOOKING_AWAY_GIVEN_NOT_CHEATING
    else:
        p_look_cheat = 1 - P_LOOKING_AWAY_GIVEN_CHEATING
        p_look_not = 1 - P_LOOKING_AWAY_GIVEN_NOT_CHEATING

    numerator = (
        P_CHEATING *
        p_face_cheat *
        p_tab_cheat *
        p_look_cheat
    )

    denominator = numerator + (
        P_NOT_CHEATING *
        p_face_not *
        p_tab_not *
        p_look_not
    )

    probability = numerator / denominator

    return probability


